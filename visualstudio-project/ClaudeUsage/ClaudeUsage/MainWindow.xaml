<ui:FluentWindow x:Class="ClaudeUsage.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:controls="clr-namespace:ClaudeUsage.Controls"
        Title="Claude Usage"
        Width="320"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        KeyDown="Window_KeyDown"
        MinHeight="270">

    <Border CornerRadius="8" Padding="16,16,16,12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Gauges: Session & Weekly side by side -->
            <Grid Grid.Row="0" Margin="0,0,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <controls:UsageGauge x:Name="SessionGauge" Grid.Column="0" Height="210" Label="Session" ResetText=""/>
                <controls:UsageGauge x:Name="WeeklyGauge" Grid.Column="1" Height="210" Label="Weekly" ResetText=""/>
            </Grid>

            <!-- Detail cards (visible when Show Details is enabled) -->
            <Grid x:Name="DetailsPanel" Grid.Row="1" Margin="0,8,0,12" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sonnet Only Card -->
                <ui:Card Grid.Column="0" Margin="0,0,6,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="SonnetLabel" Grid.Row="0" Grid.Column="0" Text="Sonnet Only" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="SonnetPercentText" Grid.Row="0" Grid.Column="1" Text="0%" FontSize="16" FontWeight="Bold" Foreground="#52D17C"/>

                        <TextBlock x:Name="ModelSpecificLabel" Grid.Row="1" Grid.ColumnSpan="2" Text="Model-specific" FontSize="10" Foreground="#78828C" Margin="0,2,0,6"/>

                        <Grid Grid.Row="2" Grid.ColumnSpan="2" Height="8" Margin="0,0,0,6">
                            <Border Background="#3A3A3A" CornerRadius="4"/>
                            <Border x:Name="SonnetFillBar" HorizontalAlignment="Left" CornerRadius="4" Width="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop x:Name="SonnetGradStart" Color="#52D17C" Offset="0"/>
                                        <GradientStop x:Name="SonnetGradEnd" Color="#22918B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Clock24" FontSize="12" Foreground="#78828C"/>
                            <TextBlock x:Name="SonnetResetText" Text="Resets in --" FontSize="10" Foreground="#78828C" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>

                <!-- Overage Card -->
                <ui:Card Grid.Column="1" Margin="6,0,0,0" VerticalAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="OverageLabel" Grid.Row="0" Grid.Column="0" Text="Overage" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="OverageAmountText" Grid.Row="0" Grid.Column="1" Text="$0.00" FontSize="16" FontWeight="Bold" Foreground="#52D17C"/>

                        <TextBlock x:Name="ExtraUsageLabel" Grid.Row="1" Grid.Column="0" Text="Extra usage" FontSize="10" Foreground="#78828C" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="OverageLimitText" Grid.Row="1" Grid.Column="1" Text="of $50 limit" FontSize="10" Foreground="#78828C" Margin="4,2,0,6"/>

                        <Grid Grid.Row="2" Grid.ColumnSpan="2" Height="8" Margin="0,0,0,6">
                            <Border Background="#3A3A3A" CornerRadius="4"/>
                            <Border x:Name="OverageFillBar" HorizontalAlignment="Left" CornerRadius="4" Width="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                        <GradientStop x:Name="OverageGradStart" Color="#52D17C" Offset="0"/>
                                        <GradientStop x:Name="OverageGradEnd" Color="#22918B" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Visibility="Hidden">
                            <ui:SymbolIcon Symbol="Clock24" FontSize="12"/>
                            <TextBlock Text="Resets in --" FontSize="10" Margin="4,0,0,0"/>
                        </StackPanel>
                    </Grid>
                </ui:Card>
            </Grid>

            <!-- Footer: always visible -->
            <Grid Grid.Row="2" Margin="0,0,0,0" VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button x:Name="RefreshButton" Icon="{ui:SymbolIcon ArrowClockwise24}" Appearance="Transparent" Padding="4" Margin="0,0,4,0" ToolTip="Refresh" Click="RefreshButton_Click"/>
                    <TextBlock x:Name="LastUpdatedText" Text="Updated --" FontSize="11" Foreground="{ui:ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button x:Name="CloseButton" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent" Padding="8" ToolTip="Close" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</ui:FluentWindow>
